# ── LLM provider keys ────────────────────────────────────────────────────────
# Pick a provider with --provider <id>. Each needs its own key below.
#
# anthropic (default): leave everything unset to reuse your Claude Code login,
#   or set ANTHROPIC_API_KEY for a standalone key.
# ANTHROPIC_API_KEY=sk-ant-...

# qwen      (Alibaba DashScope, Anthropic-compatible)
# DASHSCOPE_API_KEY=sk-...
# deepseek
# DEEPSEEK_API_KEY=sk-...
# kimi      (Moonshot)
# MOONSHOT_API_KEY=sk-...
# glm       (Z.ai)
# ZAI_API_KEY=...

# Any other Anthropic-compatible endpoint (OpenRouter-anthropic, LiteLLM, local):
#   --provider custom
# TURNKEY_BASE_URL=http://localhost:4000
# TURNKEY_AUTH_TOKEN=...           # or TURNKEY_API_KEY=...
# TURNKEY_DEFAULT_OPUS_MODEL=...   # alias remap if the endpoint needs explicit model ids
# TURNKEY_DEFAULT_SONNET_MODEL=...
# TURNKEY_DEFAULT_HAIKU_MODEL=...

# ── Default provider & per-phase mixing ──────────────────────────────────────
# TURNKEY_PROVIDER=anthropic
# Mix providers per phase (e.g. plan on Claude, write code on Qwen):
# TURNKEY_PROVIDER_PLAN=anthropic
# TURNKEY_PROVIDER_BUILD=qwen
# TURNKEY_PROVIDER_VERIFY=anthropic
# TURNKEY_PROVIDER_FINALIZE=qwen

# ── Token economy ────────────────────────────────────────────────────────────
# Per-phase model aliases (remapped to the active provider's models automatically).
# TURNKEY_MODEL_PLAN=opus
# TURNKEY_MODEL_BUILD=sonnet
# TURNKEY_MODEL_VERIFY=sonnet
# TURNKEY_MODEL_FINALIZE=haiku

# Hard cost ceiling (USD) across the whole build (safety stop).
# TURNKEY_MAX_COST_USD=8

# ── Android toolchain (usually auto-detected) ────────────────────────────────
# ANDROID_HOME=C:\Users\you\AppData\Local\Android\Sdk
